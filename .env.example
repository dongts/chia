# =============================================================================
# Chia Configuration
# =============================================================================
# cp .env.example .env && nano .env
#
# DATABASE MODES:
#   Mode 1 — Local Docker PostgreSQL (default): set DB_USER/DB_PASSWORD/DB_NAME
#   Mode 2 — External database: set DATABASE_URL, use docker-compose.external-db.yml
# =============================================================================

# --- Database (Mode 1: local Docker PostgreSQL) ------------------------------
DB_USER=chia
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=chia
DB_HOST=db
DB_PORT=5432

# --- Database (Mode 2: external — uncomment and set) -------------------------
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# USE_CONNECTION_POOLER=true

# --- Auth --------------------------------------------------------------------
JWT_SECRET=generate-with-openssl-rand-hex-32

# --- Superadmin (comma-separated emails with access to /admin) ---------------
CHIA_SUPERADMIN_EMAILS='["your-email@example.com"]'

# --- Domains (Caddy auto-HTTPS via Let's Encrypt) ---------------------------
API_DOMAIN=api.chia.dongtran.asia
APP_DOMAIN=chia.dongtran.asia
MCP_DOMAIN=mcp.chia.dongtran.asia

# --- MCP OAuth (pre-registered client for Claude.ai) -------------------------
# Generate with: openssl rand -hex 32
# MCP_OAUTH_CLIENT_ID=your-client-id
# MCP_OAUTH_CLIENT_SECRET=your-client-secret

# --- Google OAuth (Sign In With Google) ---------------------------------------
# Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# --- Sentry (error tracking) -------------------------------------------------
# SENTRY_DSN=https://xxxxx@oXXXXX.ingest.sentry.io/XXXXX

# --- Frontend URL (for CORS) -------------------------------------------------
FRONTEND_URL=https://chia.dongtran.asia

# --- Backend port (only used if running without Caddy) -----------------------
# PORT=8000
