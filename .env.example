# =============================================================================
# Chia Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Two database modes:
#
# MODE 1 — Local Docker PostgreSQL (default)
#   Set DB_USER, DB_PASSWORD, DB_NAME. The docker-compose db service handles
#   creation automatically. DATABASE_URL is built from these values.
#
# MODE 2 — External database (Supabase, RDS, Neon, another server, etc.)
#   Set DATABASE_URL directly. The DB_* vars and db service are ignored.
#   Comment out or remove the db service from docker-compose.prod.yml.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Option 1: Local Docker PostgreSQL (used by docker-compose db service)
DB_USER=chia
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=chia
DB_HOST=db
DB_PORT=5432

# Option 2: External database — uncomment and set this, ignore DB_* above
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# --- Connection pooler (set to true for Supabase/PgBouncer) -----------------
USE_CONNECTION_POOLER=false

# --- Auth --------------------------------------------------------------------
JWT_SECRET=generate-with-openssl-rand-hex-32

# --- App ---------------------------------------------------------------------
DOMAIN=https://chia.yourdomain.com
PORT=80
