# API backend
{$API_DOMAIN} {
	reverse_proxy backend:8000

	request_body {
		max_size 10MB
	}
}

# MCP server (Streamable HTTP)
{$MCP_DOMAIN:} {
	reverse_proxy mcp:8001
}

# Frontend (optional — only used if frontend container is running)
{$APP_DOMAIN:} {
	handle /uploads/* {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv/frontend
		file_server
		try_files {path} /index.html
	}
}
